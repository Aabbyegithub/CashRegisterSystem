
.bankcard-page {
  background: #f5f5f5;
  min-height: 100vh;
}
.bankcard-header {
  background: linear-gradient(90deg,#0E8A9E,#1CB5E0);
  color: #fff;
  font-size: 36rpx;
  text-align: center;
  padding: 40rpx 0 20rpx 0;
  position: relative;
}
.bankcard-title {
  font-size: 36rpx;
  font-weight: bold;
}
.bankcard-form {
  background: #fff;
  border-radius: 16rpx;
  margin: 30rpx 20rpx 0 20rpx;
  padding: 30rpx 20rpx 20rpx 20rpx;
}
.form-section {
  margin-bottom: 40rpx;
}
.form-switch {
  display: flex;
  align-items: center;
  margin-bottom: 20rpx;
}
.form-switch-label {
  font-size: 28rpx;
  color: #333;
  font-weight: bold;
}
.form-row {
  display: flex;
  align-items: center;
  margin-bottom: 24rpx;
}
.form-label {
  width: 28%;
  font-size: 28rpx;
  color: #333;
  text-align: right;
  margin-right: 10rpx;
}
.form-row.required .form-label::before {
  content: '*';
  color: #F04216;
  margin-right: 4rpx;
}
.form-btns {
  display: flex;
  justify-content: space-between;
  margin-top: 40rpx;
}
